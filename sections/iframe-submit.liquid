<div class="iframe-submit">
  <p class="iframe-submit-desc">
    Click the button below to display the interactive Iframe submission form in a sleek bottom panel.
  </p>
  <button type="button" class="popup-action-btn">Iframe form popup</button>

  <div class="second-popup"></div>

  <div class="equola-form-wrapper">
    <div class="drag-handle"></div>
    <div class="modal-title">
      <div class="mt-wrap">
        <h1 class="inquiry-headline">Please fill out the form below</h1>
        <p>The catalog will then be sent to you via email</p>
      </div>
      <button type="button" class="drawer-close-btn" aria-label="Close drawer">&times;</button>
    </div>
    <iframe src="{{ section.settings.iframe_src }}" title="Equola form"></iframe>
  </div>
</div>

<style>
  .iframe-submit {
    padding: 3rem 1rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .iframe-submit .iframe-submit-desc {
    font-size: 1.1rem;
    line-height: 1.6;
    color: #555555;
    margin-bottom: 2rem;
    font-family: inherit;
  }

  .iframe-submit .popup-action-btn {
    background: linear-gradient(135deg, #a50034 0%, #e60050 100%);
    color: #ffffff;
    border: none;
    padding: 1.25rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    border-radius: 50px;
    cursor: pointer;
    box-shadow: 0 8px 20px rgba(165, 0, 52, 0.3);
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    font-family: inherit;
    display: inline-block;
  }

  .iframe-submit .popup-action-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(165, 0, 52, 0.5);
    filter: brightness(1.1);
  }

  .iframe-submit .popup-action-btn:active {
    transform: translateY(-1px);
  }

  /* Second Popup Backdrop (for drawer) */
  .iframe-submit .second-popup {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 999998; /* Under the drawer which is 999999 */
  }

  .iframe-submit .second-popup.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  /* Equola Form Wrapper (Bottom Drawer) */
  .iframe-submit .equola-form-wrapper {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translate(-50%, 100%);
    width: 100%;
    max-width: 1000px;
    height: 85vh;
    background: #ffffff;
    border-radius: 24px 24px 0 0;
    box-shadow: 0 -15px 40px rgba(0, 0, 0, 0.15);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 999999;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    box-sizing: border-box;
  }

  .iframe-submit .equola-form-wrapper.is-active {
    transform: translate(-50%, 0);
  }

  .iframe-submit .drag-handle {
    width: 40px;
    height: 4px;
    background-color: rgba(255, 255, 255, 0.4);
    border-radius: 2px;
    margin: 10px auto 0 auto;
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    flex-shrink: 0;
  }

  /* Modal Title with background image */
  .iframe-submit .modal-title {
    background-image: url('https://digital-showroom.lge.com/images/myCatalog/bg_inquiry.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 3rem 2rem 2.5rem;
    text-align: center;
    position: relative;
    color: #ffffff;
    flex-shrink: 0;
  }

  .iframe-submit .modal-title .inquiry-headline {
    font-size: 1.8rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.5px;
  }

  .iframe-submit .modal-title p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
  }

  .iframe-submit .modal-title .drawer-close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #ffffff;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    padding: 0;
    backdrop-filter: blur(4px);
  }

  .iframe-submit .modal-title .drawer-close-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: rotate(90deg);
  }

  .iframe-submit .equola-form-wrapper iframe {
    width: 100%;
    height: 100%;
    border: none;
    flex-grow: 1;
    background: #ffffff;
  }

  @media (max-width: 768px) {
    .iframe-submit .equola-form-wrapper {
      height: 90vh;
      border-radius: 20px 20px 0 0;
    }

    .iframe-submit .modal-title {
      padding: 2.5rem 1.5rem 2rem;
    }

    .iframe-submit .modal-title .inquiry-headline {
      font-size: 1.4rem;
    }

    .iframe-submit .modal-title p {
      font-size: 0.9rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const actionBtn = document.querySelector('.iframe-submit .popup-action-btn');
    const secondPopup = document.querySelector('.iframe-submit .second-popup');
    const equolaWrapper = document.querySelector('.iframe-submit .equola-form-wrapper');
    const drawerCloseBtn = document.querySelector('.iframe-submit .drawer-close-btn');
    const iframe = document.querySelector('.iframe-submit .equola-form-wrapper iframe');

    function openDrawer() {
      if (secondPopup && equolaWrapper) {
        secondPopup.classList.add('is-active');
        equolaWrapper.classList.add('is-active');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeDrawer() {
      if (secondPopup && equolaWrapper) {
        secondPopup.classList.remove('is-active');
        equolaWrapper.classList.remove('is-active');
      }
      document.body.style.overflow = '';
    }

    if (actionBtn) actionBtn.addEventListener('click', openDrawer);
    if (drawerCloseBtn) drawerCloseBtn.addEventListener('click', closeDrawer);

    if (secondPopup) {
      secondPopup.addEventListener('click', closeDrawer);
    }

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeDrawer();
      }
    });

    // Capture response messages sent by the iframe on form submit
    window.addEventListener('message', function (event) {
      console.log('Iframe submit result:', event.data);
      closeDrawer();
    });
  });
</script>

{% schema %}
{
  "name": "iFrame Submit",
  "tag": "div",
  "settings": [
    {
      "id": "iframe_src",
      "label": "iFrame src",
      "type": "text",
      "default": "https://b2bmkt.lge.com/IT_Showroom_catalog_main?vertical=V003&place=P003006&verticalName=Corporate%20%2F%20Office&placeName=Others&fromQR=N"
    }
  ],
  "presets": [
    {
      "name": "iFrame Submit"
    }
  ]
}
{% endschema %}
