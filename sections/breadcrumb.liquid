{% liquid
  assign breadcrumb_collection = collection

  if breadcrumb_collection == blank
    assign primary_collection = product.metafields.custom.primary_collection.value
    if primary_collection != blank
      assign breadcrumb_collection = primary_collection
    endif
  endif

  if breadcrumb_collection == blank
    for item_collection in product.collections
        assign breadcrumb_collection = item_collection
        break
    endfor
  endif
%}    
{% if template == 'collection' or template contains 'product' %}
<div class="breadcrumb-section section section--page-width">
    <nav class="breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span>/</span>   
        {% if template == 'collection' %}
            {%- assign father = collection.metafields.custom.farther_collection.value -%}
            {%- if father != blank -%}
                <a href="{{ father.url }}">{{ father.title }}</a>
                <span>/ </span>
            {%- endif -%}
            <a href="{{ collection.url }}">{{ collection.title }} </a>  
        {%  endif %}        
        {% if template contains 'product' %}
        {% if breadcrumb_collection != blank %}
            {%- assign father = breadcrumb_collection.metafields.custom.farther_collection.value -%}
            {%- if father != blank -%}
                <a href="{{ father.url }}">{{ father.title }}</a>
                <span>/</span>
            {%- endif -%}
            <a href="{{ breadcrumb_collection.url }}"> {{ breadcrumb_collection.title }}</a>   
            <span>/</span>     
        {% endif %}        
        <span>{{ product.title }}</span>
        {% endif %}
    </nav>
</div>
{% endif %}

{%  if template == 'collection' %}
  {%- assign current_handle = collection.handle -%}
  {%- assign sub_collections_exist = false -%}

  {%- capture sub_collections_html -%}
    {%- for col in collections -%}
      {%- assign father = col.metafields.custom.farther_collection.value -%}
      {%- if father != blank and father.handle == current_handle -%}
        {%- assign sub_collections_exist = true -%}
        <div class="sub-collection-card">
          <a href="{{ col.url }}" class="sub-collection-card__link">
            <div class="sub-collection-card__image-wrapper">
              {%- if col.image -%}
                {{ col.image | image_url: width: 300 | image_tag: loading: 'lazy', alt: col.title, class: 'sub-collection-card__image' }}
              {%- elsif col.products.first.featured_image -%}
                {{ col.products.first.featured_image | image_url: width: 300 | image_tag: loading: 'lazy', alt: col.title, class: 'sub-collection-card__image' }}
              {%- else -%}
                {{ 'collection-placeholder-1' | placeholder_svg_tag: 'sub-collection-card__image placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="sub-collection-card__title">
              {{ col.title }}
            </div>
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}

  {%- if sub_collections_exist -%}
    <style>
      .sub-collections-section {
        margin-block-start: 1.5rem;
        margin-block-end: 2.5rem;
      }
      .sub-collections-container {
        width: 100%;
      }
      .sub-collections-heading {
        margin-bottom: 1rem;
        font-size: 1.5rem;
        font-family: var(--font-heading--family, inherit);
      }
      .sub-collections-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
      }
      @media screen and (min-width: 750px) {
        .sub-collections-grid {
          grid-template-columns: repeat(4, 1fr);
          gap: 1.5rem;
        }
      }
      @media screen and (min-width: 990px) {
        .sub-collections-grid {
          grid-template-columns: repeat(6, 1fr);
        }
      }
      .sub-collection-card {
        position: relative;
        background: var(--color-background-secondary, #f4f4f4);
        border-radius: var(--border-radius-card, 8px);
        overflow: hidden;
        transition: transform 0.2s ease-in-out;
      }
      .sub-collection-card:hover {
        transform: translateY(-4px);
      }
      .sub-collection-card__link {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        height: 100%;
      }
      .sub-collection-card__image-wrapper {
        position: relative;
        aspect-ratio: 1 / 1;
        overflow: hidden;
        background-color: var(--color-background-tertiary, #eaeaea);
      }
      .sub-collection-card__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
      }
      .sub-collection-card:hover .sub-collection-card__image {
        transform: scale(1.05);
      }
      .sub-collection-card__title {
        padding: 0.75rem;
        text-align: center;
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--color-foreground, #000);
      }
    </style>
    <div class="sub-collections-section section section--page-width">
      <div class="sub-collections-container">
        <h3 class="sub-collections-heading">Sub-collections</h3>
        <div class="sub-collections-grid">
          {{ sub_collections_html }}
        </div>
      </div>
    </div>
  {%- endif -%}
{%  endif %}

{% schema %}
{
  "name": "Breadcrumb",
  "class": "section-breadcrumb",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
      ],
  "presets": [
    {
      "name": "Breadcrumb"
    }
  ]
}
{% endschema %}