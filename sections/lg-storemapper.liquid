{{ 'lg-storemapper.css' | asset_url | stylesheet_tag }}
<script
  src="{{ 'lg-storemapper.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{%- comment -%} Extract Unique Business Units and Countries dynamically from blocks for filters {%- endcomment -%}
{%- assign unique_countries = "" -%}
{%- assign unique_bus = "" -%}

{%- for block in section.blocks -%}
  {%- if block.type == 'store' -%}
    {%- assign country = block.settings.country | strip -%}
    {%- assign bu = block.settings.business_unit | strip -%}
    
    {%- if country != "" -%}
      {%- assign country_check = country | downcase -%}
      {%- assign unique_countries_downcase = unique_countries | downcase -%}
      {%- unless unique_countries_downcase contains country_check -%}
        {%- if unique_countries != "" -%}{%- assign unique_countries = unique_countries | append: "||" -%}{%- endif -%}
        {%- assign unique_countries = unique_countries | append: country -%}
      {%- endunless -%}
    {%- endif -%}

    {%- if bu != "" -%}
      {%- assign bu_check = bu | downcase -%}
      {%- assign unique_bus_downcase = unique_bus | downcase -%}
      {%- unless unique_bus_downcase contains bu_check -%}
        {%- if unique_bus != "" -%}{%- assign unique_bus = unique_bus | append: "||" -%}{%- endif -%}
        {%- assign unique_bus = unique_bus | append: bu -%}
      {%- endunless -%}
    {%- endif -%}
  {%- endif -%}{%- endfor -%}

{%- assign country_arr = unique_countries | split: "||" | sort -%}
{%- assign bu_arr = unique_bus | split: "||" | sort -%}

<section 
  class="storemapper-section" 
  id="storemapper-{{ section.id }}" 
  aria-labelledby="storemapper-title-{{ section.id }}"
  data-google-api-key="{{ section.settings.google_maps_api_key | escape }}"
>
  <div class="storemapper-header">
    <h1 class="storemapper-title" id="storemapper-title-{{ section.id }}">{{ section.settings.title }}</h1>
    <p class="storemapper-subtitle">{{ section.settings.subtitle }}</p>
  </div>

  <!-- Filter Selector Card -->
  <div class="storemapper-filter-card">
    <form class="storemapper-filter-form" autocomplete="off" onsubmit="return false;">
      
      <!-- Business Unit Select -->
      <div class="storemapper-filter-group">
        <label for="business-unit-select">
          {{ section.settings.bu_label }}
          <span class="required-asterisk" aria-hidden="true">*</span>
        </label>
        <div class="storemapper-input-wrapper">
          <select id="business-unit-select" class="storemapper-select" required>
            <option value="">{{ section.settings.bu_placeholder }}</option>
            {%- for bu in bu_arr -%}
              <option value="{{ bu }}">{{ bu }}</option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <!-- Country Select -->
      <div class="storemapper-filter-group">
        <label for="country-select">
          {{ section.settings.country_label }}
          <span class="required-asterisk" aria-hidden="true">*</span>
        </label>
        <div class="storemapper-input-wrapper">
          <select id="country-select" class="storemapper-select" required>
            <option value="">{{ section.settings.country_placeholder }}</option>
            {%- comment -%} Countries are generated dynamically by JS relative to selected Business Unit {%- endcomment -%}
            {%- for country in country_arr -%}
              <option value="{{ country }}">{{ country }}</option>
            {%- endfor -%}
          </select>
        </div>
      </div>

      <!-- Address Input -->
      <div class="storemapper-filter-group">
        <label for="address-search-input">
          {{ section.settings.search_label }}
          <span class="required-asterisk" aria-hidden="true">*</span>
        </label>
        <div class="storemapper-input-wrapper storemapper-input-wrapper-search">
          <input 
            type="text" 
            id="address-search-input" 
            class="storemapper-input" 
            placeholder="{{ section.settings.search_placeholder }}"
            required
          />
        </div>

        <!-- Suggestion list container -->
        <div class="storemapper-suggestions-container" id="address-suggestions-box"></div>
      </div>

      <!-- Search Button -->
      <button type="submit" class="storemapper-search-button">
        {{ section.settings.search_btn_text }}
      </button>
    </form>
  </div>

  <!-- Interactive Map & List Layout -->
  <div class="storemapper-layout">
    
    <!-- Collapsible Sidebar -->
    <aside class="storemapper-sidebar" aria-label="Store locations sidebar">
      <!-- Collapse toggle button -->
      <button class="storemapper-sidebar-toggle" aria-label="Toggle store list panel" aria-expanded="true">
        <svg viewBox="0 0 10 10">
          <path d="M7 1L3 5l4 4" />
        </svg>
      </button>

      <div class="storemapper-sidebar-header">
        <span class="storemapper-results-count">
          <span class="storemapper-results-count-number">0</span> Results Found
        </span>
      </div>

      <div class="storemapper-store-list">
        {%- assign counter = 1 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'store' -%}
            <div 
              class="storemapper-store-item" 
              data-id="{{ block.id }}"
              data-name="{{ block.settings.name | escape }}"
              data-business-unit="{{ block.settings.business_unit | escape }}"
              data-country="{{ block.settings.country | escape }}"
              data-address="{{ block.settings.address | escape }}"
              data-lat="{{ block.settings.latitude | escape }}"
              data-lng="{{ block.settings.longitude | escape }}"
              data-phone="{{ block.settings.phone | escape }}"
              data-email="{{ block.settings.email | escape }}"
              role="button"
              tabindex="0"
            >
              <div class="store-marker-pin-wrapper">
                <div class="store-marker-number-pin">
                  <svg viewBox="0 0 24 30" width="24" height="30">
                    <path fill="#e50020" d="M12,0 C5.37,0 0,5.37 0,12 C0,21 12,30 12,30 C12,30 24,21 24,12 C24,5.37 18.63,0 12,0 Z" />
                    <circle fill="#ffffff" cx="12" cy="11" r="7" />
                  </svg>
                  <span>{{ counter }}</span>
                </div>
              </div>
              
              <div class="store-details">
                <div class="store-title-row">
                  <!-- Office/Branch Outline Icon -->
                  <svg class="store-type-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                    <circle cx="12" cy="10" r="3"/>
                  </svg>
                  <h2 class="store-name">{{ block.settings.name }}</h2>
                </div>
                <address class="store-address">{{ block.settings.address }}</address>
                {%- if block.settings.phone != blank -%}
                  <a href="tel:{{ block.settings.phone }}" class="store-contact-row">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    <span>{{ block.settings.phone }}</span>
                  </a>
                {%- endif -%}
                {%- if block.settings.email != blank -%}
                  <a href="mailto:{{ block.settings.email }}" class="store-contact-row">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2"/>
                      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                    <span>{{ block.settings.email }}</span>
                  </a>
                {%- endif -%}
              </div>
            </div>
            {%- assign counter = counter | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    </aside>

    <!-- Map Canvas -->
    <div class="storemapper-map-container">
      <button class="map-fullscreen-btn" aria-label="Toggle fullscreen map view">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3" />
        </svg>
      </button>
      <div class="storemapper-map"></div>

      <!-- No Results / Empty State -->
      <div class="storemapper-empty-state" style="display: none;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <p>No locations found matching your filter options.</p>
      </div>
    </div>

  </div>
</section>

