

{% assign form_id = block.id | default: section.id | prepend: 'ContactForm-' %}

<!-- Step 1: Inquiry Type Selection -->
<div class="pdp-wizard-step step-1" id="pdp-step-1">
  <div class="pdp-inquiry-header">
    <p class="pdp-inquiry-intro">We provide customized solutions to help your business achieve optimized growth.</p>
  </div>
  
  <div class="pdp-inquiry-grid">
    <!-- Card 1: Quotation or Purchase Consultation -->
    <div class="pdp-inquiry-card" data-value="Quotation or Purchase Consultation">
      <div class="pdp-inquiry-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2H5a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V10z"/>
          <polyline points="12 2 12 10 20 10"/>
          <line x1="6" y1="14" x2="18" y2="14"/>
          <line x1="6" y1="18" x2="14" y2="18"/>
          <circle cx="18" cy="4" r="3.5" fill="#ffffff" stroke="currentColor" stroke-width="1.2"/>
          <path d="M18 2.2v3.6" stroke-width="1.2"/>
          <path d="M16.8 3.2c.4-.4 1.2-.4 1.6.1c.3.4.1 1.1-.4 1.3c-.5.2-.7.8-.4 1.3c.3.5 1.1.5 1.5.1" stroke-width="1.2"/>
        </svg>
      </div>
      <div class="pdp-inquiry-label">Quotation or Purchase Consultation</div>
    </div>

    <!-- Card 2: Technical Consultation -->
    <div class="pdp-inquiry-card" data-value="Technical Consultation">
      <div class="pdp-inquiry-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="11" r="2.5"/>
          <path d="M7 18c0-2.5 2.2-3.5 5-3.5s5 1 5 3.5"/>
          <circle cx="7.5" cy="12.5" r="2"/>
          <path d="M4 18c0-2 2-2.5 3.5-2.5c1 .1 1.8.3 2.5.6"/>
          <circle cx="16.5" cy="12.5" r="2"/>
          <path d="M20 18c0-2-2-2.5-3.5-2.5c-1 .1-1.8.3-2.5.6"/>
          <circle cx="12" cy="4.5" r="1.5"/>
          <path d="M12 2.2v.8M12 6v.8M9.7 4.5h.8M13.5 4.5h.8M10.4 2.9l.5.5M13.1 5.6l.5.5M13.6 2.9l-.5.5M10.9 5.6l-.5.5"/>
        </svg>
      </div>
      <div class="pdp-inquiry-label">Technical Consultation</div>
    </div>

    <!-- Card 3: Request for Partnership -->
    <div class="pdp-inquiry-card" data-value="Request for Partnership">
      <div class="pdp-inquiry-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 11l4 4a2.5 2.5 0 0 0 3.5 0l2.5-2.5a2.5 2.5 0 0 0 0-3.5L20 3"/>
          <path d="M8 19l-4-4a2.5 2.5 0 0 1 0-3.5l2.5-2.5a2.5 2.5 0 0 1 3.5 0L14 13"/>
          <path d="M12 11l4 4m-2-6l4 4"/>
          <circle cx="12" cy="5" r="3" fill="#ffffff" stroke="currentColor" stroke-width="1.2"/>
          <path d="M10.8 5l.8.8L13.2 4.2" stroke-width="1.2"/>
        </svg>
      </div>
      <div class="pdp-inquiry-label">Request for Partnership</div>
    </div>

    <!-- Card 4: Customer Suggestions -->
    <div class="pdp-inquiry-card" data-value="Customer Suggestions">
      <div class="pdp-inquiry-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15c1.6-1.6 2-4.1.8-6.1C20.4 6.5 17.9 5 15.1 5 10 5 5.8 8.8 5.8 13.5c0 1.9.7 3.7 2 5.1l-1 2.4c-.1.3 0 .7.3.9c.1.1.2.1.3.1l2.8-1.1c1.6.7 3.4 1.1 5.3 1.1c.5 0 1 0 1.5-.1"/>
          <circle cx="14" cy="11" r="2.5"/>
          <path d="M12.5 13.5h3v1h-3v-1z M13 14.5h2v.5h-2v-.5z"/>
          <path d="M14 6.5v1M10.8 7.8l.7.7M17.2 7.8l-.7.7M9.5 11h1M17.5 11h1"/>
        </svg>
      </div>
      <div class="pdp-inquiry-label">Customer Suggestions</div>
    </div>

    <!-- Card 5: Others -->
    <div class="pdp-inquiry-card" data-value="Others">
      <div class="pdp-inquiry-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18v3l4-3h6a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h4z"/>
          <circle cx="7" cy="10" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="12" cy="10" r="1.5" fill="currentColor" stroke="none"/>
          <circle cx="17" cy="10" r="1.5" fill="currentColor" stroke="none"/>
        </svg>
      </div>
      <div class="pdp-inquiry-label">Others</div>
    </div>
  </div>
  
  <!-- Hidden form input for inquiry type -->
  <input type="hidden" name="contact[inquiry_type]" id="contact-inquiry-type-val" form="{{ form_id }}">
</div>

<!-- Step 2: Product & Category Selection -->
<div class="pdp-wizard-step step-2" id="pdp-step-2" style="display: none;">
  <div class="pdp-selection-section">
    <h2 class="pdp-selection-title">1. Tell us what you're looking for</h2>
    
    <!-- Recently Viewed Selector -->
    <div class="recently-viewed-dropdown-container">
      <button type="button" class="recently-viewed-trigger" id="recently-viewed-trigger" aria-expanded="false">
        Select from recently viewed products.
        <span class="dropdown-chevron">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </span>
      </button>
      
      <div class="recently-viewed-dropdown" id="recently-viewed-dropdown" style="display: none;">
        <div class="recently-viewed-list" id="recently-viewed-list">
          <!-- populated by JS -->
          <div class="recently-viewed-empty">No recently viewed products found.</div>
        </div>
      </div>
    </div>

    <!-- Preview of selected recently viewed product at top -->
    <div class="selected-pdp-card" id="selected-pdp-card" style="display: none;">
      <!-- populated by JS -->
    </div>

    <p class="pdp-selection-note">We'll prepare the details in advance so we can focus directly on your needs.</p>
    <div class="pdp-required-fields"><span class="pdp-required-star">*</span> Required Fields</div>

    <!-- 4 Columns Grid -->
    <div class="pdp-selector-columns">
      <!-- Category Column -->
      <div class="pdp-col pdp-col-category">
        <div class="pdp-col-header">Category <span class="pdp-required-star">*</span></div>
        <div class="pdp-col-body pdp-scrollbar" id="category-col-body">
          <!-- populated by JS -->
        </div>
      </div>

      <!-- Sub Category Column -->
      <div class="pdp-col pdp-col-subcategory">
        <div class="pdp-col-header">Sub Category</div>
        <div class="pdp-col-body pdp-scrollbar" id="subcategory-col-body">
          <div class="pdp-col-placeholder">Please select a Category</div>
        </div>
      </div>

      <!-- Model Column -->
      <div class="pdp-col pdp-col-model">
        <div class="pdp-col-header">Model</div>
        <div class="pdp-col-body pdp-scrollbar" id="model-col-body">
          <div class="pdp-col-placeholder">Please select a Sub Category</div>
        </div>
      </div>

      <!-- Selected Product (4th column) -->
      <div class="pdp-col pdp-col-preview pdp-col-empty" id="pdp-col-preview">
        <div class="pdp-preview-container" id="pdp-preview-container">
          <div class="pdp-no-product">No product</div>
        </div>
      </div>
    </div>

    <!-- Hidden form inputs -->
    <input type="hidden" name="contact[category]" id="contact-category-val" form="{{ form_id }}">
    <input type="hidden" name="contact[subcategory]" id="contact-subcategory-val" form="{{ form_id }}">
    <input type="hidden" name="contact[model]" id="contact-model-val" form="{{ form_id }}">
    <input type="hidden" name="contact[product_title]" id="contact-product-title-val" form="{{ form_id }}">
    <input type="hidden" name="contact[product_sku]" id="contact-product-sku-val" form="{{ form_id }}">
  </div>

  <div class="pdp-wizard-nav">
    <button type="button" class="pdp-btn pdp-btn-secondary" id="pdp-prev-to-step1">Previous</button>
    <button type="button" class="pdp-btn pdp-btn-primary" id="pdp-next-to-step3" disabled>Next</button>
  </div>
</div>

