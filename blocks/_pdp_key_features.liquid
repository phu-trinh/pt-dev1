<script id="productJson" type="application/json">
  {{ product.metafields.custom.spec_data }}
</script>

{% case product.type %}
  {% when 'monitors' %}
    {% render 'lg-pdp-keyfeatures-monitors' %}
  {% when 'laptops' %}
    {% render 'lg-pdp-keyfeatures-laptops' %}
  {% when 'projectors' %}
    {% render 'lg-pdp-keyfeatures-projectors' %}
  {% when 'thinclients' %}
    {% render 'lg-pdp-keyfeatures-thinclients' %}
  {% when 'pcaccessories' %}
    {% render 'lg-pdp-keyfeatures-pcaccessories' %}
  {% when 'medicaldisplays' %}
    {% render 'lg-pdp-keyfeatures-medicaldisplays' %}
{% endcase %}


{% style %}
  .pdp-key-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .pdp-key-features > div {
    display: flex;
    flex-direction: column;
  }

  .pdp-key-features .heading {
    font-weight: 600;
  }
{% endstyle %}

{% schema %}
{
  "name": "Key Features",
  "tag": "div",
  "settings": [
    {
      "type": "header",
      "content": "Key Features"
    }
  ],
  "presets": [
    {
      "name": "Key Features"
    }
  ]
}
{% endschema %}
