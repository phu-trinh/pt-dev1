<div class="pdp-key-features {{ product.type | handleize }}">
  <div class="key_1">
    <span class="heading">Operating System</span>
    <span>
      <span class="value" data-getJsonValue="Operating System"></span>
    </span>
  </div>
  <div class="key_2">
    <span class="heading">Resolution + Refresh Rate (Max.)</span>
    <span>
      <span class="value" data-getJsonValue="Resolution"></span>
      <span class="value" data-getJsonValue="Refresh Rate (Max.) [Hz]" data-maxResolution></span>
    </span>
  </div>
  <div class="key_3">
    <span class="heading">Panel Type</span><span class="value" data-getJsonValue="Panel Type"></span>
  </div>
  <div class="key_3_1">
    <span class="heading">Color Gamut</span>
    <span>
      <span class="value" data-getJsonValue="Color Gamut (Typ.)" data-remove-min-type></span>
    </span>
  </div>
  <div class="key_4">
    <span class="heading">Display Position Adjustments</span
    ><span class="value" data-getJsonValue="Display Position Adjustments"></span>
  </div>
  <div class="key_5" data-getJsonValue="Dimensions">
    <span class="heading">Ports</span>
    <span class="key5_data">
      <span
        class="value"
        {% unless product.metafields.custom.hdmi != blank %}
          data-getJsonValue="HDMI" data-text="HDMI" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.hdmi %}{{ product.metafields.custom.hdmi.value }}{% endif -%}
      </span>
      <span
        class="value"
        {% unless product.metafields.custom.displayport != blank %}
          data-getJsonValue="DisplayPort" data-text="Display Port" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.displayport %}{{ product.metafields.custom.displayport.value }}{% endif -%}
      </span>
      <span
        class="value"
        {% unless product.metafields.custom.thunderbolt != blank %}
          data-getJsonValue="Thunderbolt" data-text="Thunderbolt" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.thunderbolt %}{{ product.metafields.custom.thunderbolt.value }}{% endif -%}
      </span>
      <span
        class="value"
        {% unless product.metafields.custom.usb_c != blank %}
          data-getJsonValue="USB-C" data-text="USB-C" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.usb_c %}{{ product.metafields.custom.usb_c.value }}{% endif -%}
      </span>
      <span
        class="value"
        {% unless product.metafields.custom.usb_upstream_port != blank %}
          data-getJsonValue="USB Upstream Port" data-text="USB Upstream Port" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.usb_upstream_port -%}
          {{- product.metafields.custom.usb_upstream_port.value -}}
        {%- endif -%}
      </span>
      <span
        class="value"
        {% unless product.metafields.custom.usb_downstream_port != blank %}
          data-getJsonValue="USB Downstream Port" data-text="USB Downstream Port" data-hdmiyesno
        {% endunless %}
      >
        {%- if product.metafields.custom.usb_downstream_port -%}
          {{- product.metafields.custom.usb_downstream_port.value -}}
        {%- endif -%}
      </span>
      <span class="value" data-getJsonValue="D-Sub" data-sw-yesno></span>
      <span class="value" data-getJsonValue="LAN (RJ-45)" data-sw-yesno></span>
      <span class="value" data-getJsonValue="Daisy Chain" data-sw-yesno></span>
      <span class="value" data-getJsonValue="Bulit-in KVM" data-sw-yesno></span>
      <span class="value" data-getJsonValue="DVI-D" data-sw-yesno></span>
    </span>
  </div>
  <div class="key_6">
    <span class="heading">SW APPLICATION</span>
    <span>
      <span class="value" data-getJsonValue="LG Switch" data-sw-yesno></span>
      <span class="value" data-getJsonValue="LG Calibration Studio (True Color Pro)" data-sw-yesno></span>
      <span class="value" data-getJsonValue="Dual Controller" data-sw-yesno></span>
    </span>
  </div>
</div>

<script>
  (function () {
    const productJsonEl = document.getElementById('productJson');
    if (!productJsonEl) return;

    try {
      const rawText = productJsonEl.textContent.trim();
      if (!rawText) return;

      let data = JSON.parse(rawText);
      if (typeof data === 'string') {
        data = JSON.parse(data);
      }

      if (!data) return;
      console.log('spec data:', data);

      // Flatten spec data to map normalized keys to values
      const specMap = {};
      const priorityMap = {};

      const getPriority = (path) => {
        const lowerPath = path.toLowerCase();
        if (lowerPath.includes('connectivity')) return 10;
        if (lowerPath.includes('display')) return 5;
        if (lowerPath.includes('accessory')) return 1;
        return 2; // default priority
      };

      function traverse(obj, path = '') {
        if (obj && typeof obj === 'object') {
          for (const key in obj) {
            if (Object.prototype.hasOwnProperty.call(obj, key)) {
              const val = obj[key];
              if (val && typeof val === 'object') {
                traverse(val, path ? path + '.' + key : key);
              } else {
                const normalized = key.toLowerCase().replace(/[^a-z0-9]/g, '');
                const lowerKey = key.toLowerCase();
                const priority = getPriority(path);

                if (specMap[normalized] === undefined || priority > (priorityMap[normalized] || 0)) {
                  specMap[normalized] = val;
                  priorityMap[normalized] = priority;
                }
                if (specMap[lowerKey] === undefined || priority > (priorityMap[lowerKey] || 0)) {
                  specMap[lowerKey] = val;
                  priorityMap[lowerKey] = priority;
                }
              }
            }
          }
        }
      }
      traverse(data);

      // Populate elements with data-getJsonValue
      document.querySelectorAll('[data-getJsonValue]').forEach((element) => {
        const attrValue = element.getAttribute('data-getJsonValue');
        if (!attrValue) return;

        const normalizedAttr = attrValue.toLowerCase().replace(/[^a-z0-9]/g, '');
        const targetValue =
          specMap[normalizedAttr] !== undefined ? specMap[normalizedAttr] : specMap[attrValue.toLowerCase()];

        if (element.hasAttribute('data-YESNO')) {
          if (targetValue !== undefined && targetValue !== null) {
            const valStr = targetValue.toString().toUpperCase();
            if (valStr.includes('YES')) {
              element.style.display = '';
            } else if (valStr.includes('NO')) {
              element.style.display = 'none';
            } else {
              element.style.display = 'none';
            }
          } else {
            element.style.display = 'none';
          }
          return;
        }

        if (element.hasAttribute('data-sw-yesno')) {
          if (targetValue !== undefined && targetValue !== null) {
            const valStr = targetValue.toString().toUpperCase();
            if (valStr.includes('YES')) {
              element.style.display = '';
              element.textContent = attrValue;
            } else {
              element.style.display = 'none';
              element.textContent = '';
            }
          } else {
            element.style.display = 'none';
            element.textContent = '';
          }
          return;
        }

        if (element.hasAttribute('data-hdmiyesno') || element.hasAttribute('data-displayportyesno')) {
          const displayText = element.getAttribute('data-text') || 'HDMI';
          if (targetValue !== undefined && targetValue !== null) {
            element.setAttribute('data-jsonValue', targetValue);
            const valStr = targetValue.toString().toLowerCase();
            const upDownMatch = valStr.match(/(\d+)\s*ea\s*,\s*(\d+)\s*up\s*\/\s*(\d+)\s*down/i);
            if (upDownMatch) {
              element.style.display = '';
              element.textContent = `${displayText} x${upDownMatch[1]} (Up x${upDownMatch[2]}, Down x${upDownMatch[3]})`;
              return;
            }

            // Check for "via .../Xea" pattern
            const viaMatches = [...valStr.matchAll(/via\s+([a-zA-Z0-9\s-]+)\s*\/\s*(\d+)\s*(?:ea|ae)/gi)];
            if (viaMatches.length > 0) {
              const rawMatches = [...targetValue.matchAll(/via\s+([a-zA-Z0-9\s-]+)\s*\/\s*(\d+)\s*(?:ea|ae)/gi)];
              const subParts = rawMatches.map((m) => `via ${m[1].trim()} x${m[2]}`);
              const totalCount = rawMatches.reduce((sum, m) => sum + parseInt(m[2], 10), 0);

              element.style.display = '';
              if (totalCount > 1) {
                element.textContent = `${displayText} x${totalCount} (${subParts.join(', ')})`;
              } else {
                element.textContent = `${displayText} (${subParts.join(', ')})`;
              }
              return;
            }

            // Check for "Name/Xea" pattern (without via)
            const subPortMatches = [...valStr.matchAll(/([a-zA-Z0-9\s-]+)\s*\/\s*(\d+)\s*(?:ea|ae)/gi)];
            if (subPortMatches.length > 0) {
              const rawMatches = [...targetValue.matchAll(/([a-zA-Z0-9\s-]+)\s*\/\s*(\d+)\s*(?:ea|ae)/gi)];
              const subParts = rawMatches.map((m) => `via ${m[1].trim()} x${m[2]}`);

              element.style.display = '';
              element.textContent = `${displayText}(${subParts.join(', ')})`;
              return;
            }

            let count = 0;
            const inOutMatch = valStr.match(/in\s*(\d+)\s*(?:ea|ae)\s*\/\s*out\s*(\d+)\s*(?:ea|ae)/i);
            if (inOutMatch) {
              count = parseInt(inOutMatch[1], 10) + parseInt(inOutMatch[2], 10);
            } else {
              const normDisplay = displayText.toLowerCase().replace(/[^a-z0-9]/g, '');
              const parts = valStr.split(/[,;]/);
              let foundMatch = false;
              for (const part of parts) {
                const normPart = part.toLowerCase().replace(/[^a-z0-9]/g, '');
                if (normPart.includes(normDisplay)) {
                  const match = part.match(/(\d+)\s*(?:ea|ae)/i);
                  if (match) {
                    count = parseInt(match[1], 10);
                    foundMatch = true;
                    break;
                  }
                }
              }
              if (!foundMatch) {
                const match =
                  valStr.match(/([2-5])\s*(?:ea|ae)/i) ||
                  valStr.match(/\(\s*([2-5])\s*\)/) ||
                  valStr.match(/^\s*([2-5])\s*$/);
                if (match) {
                  count = parseInt(match[1], 10);
                }
              }
            }

            if (count > 1) {
              element.style.display = '';
              element.textContent = `${displayText} x${count}`;
            } else if (
              valStr.includes('yes') ||
              valStr.includes('1ea') ||
              valStr.includes('1ae') ||
              /\b1\b/.test(valStr)
            ) {
              element.style.display = '';
              element.textContent = displayText;
            } else if (valStr.trim() !== '' && !valStr.includes('no')) {
              element.style.display = '';
              element.textContent = displayText;
            } else {
              element.style.display = 'none';
              element.textContent = '';
            }
          } else {
            element.style.display = 'none';
            element.textContent = '';
          }
          return;
        }

        if (targetValue !== undefined && targetValue !== null) {
          // If the element has class "value" or is a span, set its text.
          // Otherwise, find a child with class "value" to set.
          const target =
            element.tagName === 'SPAN' || element.classList.contains('value')
              ? element
              : element.querySelector('.value') || element;

          let displayValue = targetValue;
          if (attrValue === 'Size [Inch]') {
            const valStr = targetValue.toString().trim();
            displayValue = valStr ? (valStr.includes('"') ? valStr : valStr + '"') : '';
          } else if (attrValue === 'Size [cm]') {
            const valStr = targetValue.toString().trim();
            displayValue = valStr ? (valStr.toLowerCase().includes('cm') ? valStr : valStr + ' cm') : '';
          } else if (attrValue === 'Display Position Adjustments') {
            displayValue = targetValue
              .toString()
              .replace(/\s*\/\s*/g, ' / ')
              .trim();
          } else if (element.hasAttribute('data-maxResolution')) {
            const valStr = targetValue.toString().trim();
            displayValue = valStr ? (/hz$/i.test(valStr) ? valStr : valStr + 'Hz') : '';
          }
          if (element.hasAttribute('data-remove-min-type')) {
            const stripped = displayValue
              .toString()
              .replace(/\s*\([^)]*\)/g, '')
              .trim();
            displayValue = stripped ? stripped + ' (Typ.)' : '';
          }
          target.textContent = displayValue;
        }
      });

      // Format commas for .key5_data elements
      const portElements = Array.from(document.querySelectorAll('.key5_data .value')).filter(
        (el) => el.style.display !== 'none' && el.textContent.trim() !== ''
      );
      portElements.forEach((el, index) => {
        let text = el.textContent.replace(/,\s*$/, '').trim();
        if (index < portElements.length - 1) {
          el.textContent = text + ', ';
        } else {
          el.textContent = text;
        }
      });

      // Format commas for .key_6 elements
      const swElements = Array.from(document.querySelectorAll('.key_6 .value')).filter(
        (el) => el.style.display !== 'none' && el.textContent.trim() !== ''
      );
      swElements.forEach((el, index) => {
        let text = el.textContent.replace(/,\s*$/, '').trim();
        if (index < swElements.length - 1) {
          el.textContent = text + ', ';
        } else {
          el.textContent = text;
        }
      });

      // Show/hide .key_3_1 based on whether Color Gamut (Min.) or (Typ.) has a value
      const colorGamutMinVal =
        specMap['colorgamutmin'] !== undefined ? specMap['colorgamutmin'] : specMap['color gamut (min.)'];
      const colorGamutTypVal =
        specMap['colorgamuttyp'] !== undefined ? specMap['colorgamuttyp'] : specMap['color gamut (typ.)'];
      const key31El = document.querySelector('.key_3_1');
      if (key31El) {
        const hasColorGamut =
          (colorGamutMinVal !== undefined && colorGamutMinVal !== null && colorGamutMinVal.toString().trim() !== '') ||
          (colorGamutTypVal !== undefined && colorGamutTypVal !== null && colorGamutTypVal.toString().trim() !== '');
        key31El.style.display = hasColorGamut ? '' : 'none';
      }

      // Show/hide .key_6 based on whether it has any visible populated value
      const key6El = document.querySelector('.key_6');
      if (key6El) {
        let hasValue = false;
        key6El.querySelectorAll('[data-getJsonValue]').forEach((el) => {
          if (el.style.display !== 'none' && el.textContent.trim() !== '') {
            hasValue = true;
          }
        });
        // Show .key_6 when it has value, hide when it doesn't
        key6El.style.display = hasValue ? '' : 'none';
      }
    } catch (e) {
      console.warn('Error parsing or processing key features JSON:', e);
    }
  })();
</script>
